{
  "version": "0.2.0",
  "configurations": [
    // ─────────────────────────────────────────────
    // CHROME — Web preview (mobile viewport)
    // ─────────────────────────────────────────────
    {
      "name": "Chrome — Production",
      "request": "launch",
      "type": "dart",
      "program": "apps/mobile/lib/main.dart",
      "args": [
        "-d",
        "chrome",
        "--dart-define=API_BASE_URL=https://facteur-production.up.railway.app/api/",
        "--dart-define=SUPABASE_URL=https://ykuadtelnzavrqzbfdve.supabase.co",
        "--dart-define=SUPABASE_ANON_KEY=sb_publishable_0L_kPMbe0Pk9eBdzeEsIZg_0pogzm3k",
        "--web-browser-flag",
        "--disable-web-security"
      ]
    },
    {
      "name": "Chrome — Local API",
      "request": "launch",
      "type": "dart",
      "program": "apps/mobile/lib/main.dart",
      "preLaunchTask": "Start Backend API",
      "args": [
        "-d",
        "chrome",
        "--dart-define=API_BASE_URL=http://localhost:8080/api/",
        "--dart-define=SUPABASE_URL=https://ykuadtelnzavrqzbfdve.supabase.co",
        "--dart-define=SUPABASE_ANON_KEY=sb_publishable_0L_kPMbe0Pk9eBdzeEsIZg_0pogzm3k",
        "--web-browser-flag",
        "--disable-web-security"
      ]
    },

    // ─────────────────────────────────────────────
    // iOS SIMULATOR
    // ─────────────────────────────────────────────
    {
      "name": "iOS Simulator — Production",
      "request": "launch",
      "type": "dart",
      "program": "apps/mobile/lib/main.dart",
      "args": [
        "-d",
        "iPhone",
        "--dart-define=API_BASE_URL=https://facteur-production.up.railway.app/api/",
        "--dart-define=SUPABASE_URL=https://ykuadtelnzavrqzbfdve.supabase.co",
        "--dart-define=SUPABASE_ANON_KEY=sb_publishable_0L_kPMbe0Pk9eBdzeEsIZg_0pogzm3k"
      ]
    },
    {
      "name": "iOS Simulator — Local API",
      "request": "launch",
      "type": "dart",
      "program": "apps/mobile/lib/main.dart",
      "preLaunchTask": "Start Backend API",
      "args": [
        "-d",
        "iPhone",
        // localhost est accessible depuis le simulateur iOS sans IP spéciale
        "--dart-define=API_BASE_URL=http://localhost:8080/api/",
        "--dart-define=SUPABASE_URL=https://ykuadtelnzavrqzbfdve.supabase.co",
        "--dart-define=SUPABASE_ANON_KEY=sb_publishable_0L_kPMbe0Pk9eBdzeEsIZg_0pogzm3k"
      ]
    },

    // ─────────────────────────────────────────────
    // ANDROID EMULATOR
    // Note: l'emulateur Android accède au host via 10.0.2.2 (pas localhost)
    // ─────────────────────────────────────────────
    {
      "name": "Android Emulator — Production",
      "request": "launch",
      "type": "dart",
      "program": "apps/mobile/lib/main.dart",
      "preLaunchTask": "Launch Android Emulator",
      "args": [
        "-d",
        "emulator-5554",
        "--dart-define=API_BASE_URL=https://facteur-production.up.railway.app/api/",
        "--dart-define=SUPABASE_URL=https://ykuadtelnzavrqzbfdve.supabase.co",
        "--dart-define=SUPABASE_ANON_KEY=sb_publishable_0L_kPMbe0Pk9eBdzeEsIZg_0pogzm3k"
      ]
    },
    {
      "name": "Android Emulator — Local API",
      "request": "launch",
      "type": "dart",
      "program": "apps/mobile/lib/main.dart",
      "preLaunchTask": "Android Emulator + Backend API",
      "args": [
        "-d",
        "emulator-5554",
        // 10.0.2.2 = adresse du host machine depuis l'émulateur Android
        "--dart-define=API_BASE_URL=http://10.0.2.2:8080/api/",
        "--dart-define=SUPABASE_URL=https://ykuadtelnzavrqzbfdve.supabase.co",
        "--dart-define=SUPABASE_ANON_KEY=sb_publishable_0L_kPMbe0Pk9eBdzeEsIZg_0pogzm3k"
      ]
    }
  ]
}
