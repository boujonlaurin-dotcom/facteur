# .env.example — Variables d'environnement Facteur
# Copie ce fichier en .env et renseigne les valeurs.
# Ne jamais committer .env (il est dans .gitignore).

# ─── Railway ──────────────────────────────────────────────────────────────────
# Token API Railway (Full Access pour déploiements, Read-only pour logs seuls)
# Obtenir : railway.app > Account Settings > Tokens
RAILWAY_TOKEN=

# IDs de projet/service (utilisés par les scripts de diagnostic)
# Obtenir : railway.app > Project > Settings
RAILWAY_PROJECT_ID=
RAILWAY_SERVICE_ID=

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Personal Access Token Supabase (pour le MCP et la CLI supabase)
# Obtenir : app.supabase.com > Account > Access Tokens
SUPABASE_ACCESS_TOKEN=

# URL et clé anonyme du projet (utilisées par l'API et l'app mobile)
SUPABASE_URL=https://ykuadtelnzavrqzbfdve.supabase.co
SUPABASE_ANON_KEY=

# ─── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
