{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude-hooks/post-edit-python-guardrails.sh"
          },
          {
            "type": "command",
            "command": "bash .claude-hooks/post-edit-alembic-heads.sh"
          },
          {
            "type": "command",
            "command": "bash .claude-hooks/post-edit-reminders.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude-hooks/pre-edit-alembic-deploy.sh"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "sentry": {
      "type": "stdio",
      "command": "python",
      "args": ["mcp-servers/sentry/server.py"],
      "env": {
        "SENTRY_AUTH_TOKEN": "${SENTRY_AUTH_TOKEN}",
        "SENTRY_ORG": "${SENTRY_ORG}",
        "SENTRY_PROJECT": "${SENTRY_PROJECT}"
      }
    },
    "railway": {
      "type": "stdio",
      "command": "python",
      "args": ["mcp-servers/railway/server.py"],
      "env": {
        "RAILWAY_API_TOKEN": "${RAILWAY_API_TOKEN}",
        "RAILWAY_PROJECT_ID": "${RAILWAY_PROJECT_ID}",
        "RAILWAY_SERVICE_ID": "${RAILWAY_SERVICE_ID}"
      }
    },
    "supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp?project_ref=ykuadtelnzavrqzbfdve"
    }
  }
}
