# direnv configuration — auto-loads the Nix dev shell when entering the repo.
#
# Setup (once):
#   1. Install direnv:    https://direnv.net/docs/installation.html
#   2. Install nix-direnv: https://github.com/nix-community/nix-direnv
#      (provides fast cached `use flake`)
#   3. Run `direnv allow` in this directory.
#
# Anything you want to keep machine-local (secrets, overrides) goes in
# `.envrc.local`, which is gitignored.

use flake

# Re-evaluate the shell when these change.
watch_file flake.nix
watch_file flake.lock

# Optional per-machine overrides (gitignored).
[ -f .envrc.local ] && source_env .envrc.local
